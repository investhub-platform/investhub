# Backend server base URL (without /api/v1 path)
VITE_API_BASE=http://localhost:5000
# Optional override. Defaults to sandbox checkout if not set.
VITE_PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout
# Optional. Keep false in local sandbox to avoid PayHere SDK CORS issues.
VITE_PAYHERE_USE_SDK=false
